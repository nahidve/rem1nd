generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String @id @default(cuid())
  firebaseUid String @unique
  email String? @unique
  name  String?
  pushToken String? @unique
  isPremium    Boolean   @default(false)
  premiumUntil DateTime?
  homeCurrency String    @default("INR")
  reminders     Reminder[]
  subscriptions Subscription[]
  payments      PaymentHistory[]
  groupMemberships SubscriptionGroupMember[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([firebaseUid])
}

model Reminder {
  id String @id @default(cuid())
  title    String
  amount   Decimal?
  category String
  currency String   @default("INR")
  dueDate DateTime
  repeatType RepeatType
  isActive Boolean @default(true)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@index([dueDate])
}

model Subscription {
  id String @id @default(cuid())
  name String
  amount Decimal
  currency String   @default("INR")
  category String   @default("Other")
  billingType BillingType
  renewalDate DateTime
  autoPay Boolean @default(false)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments      PaymentHistory[]
  usages        SubscriptionUsage[]
  group         SubscriptionGroup?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@index([renewalDate])
}

model SubscriptionUsage {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  usedAt         DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
}

enum RepeatType {
  ONCE
  MONTHLY
  YEARLY
}

enum BillingType {
  MONTHLY
  YEARLY
}

model PaymentHistory {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount         Decimal
  currency       String
  paymentDate    DateTime
  createdAt      DateTime     @default(now())
  @@index([userId])
  @@index([subscriptionId])
}

model SubscriptionGroup {
  id             String                    @id @default(cuid())
  subscriptionId String                    @unique
  subscription   Subscription              @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  members        SubscriptionGroupMember[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}

model SubscriptionGroupMember {
  id              String            @id @default(cuid())
  groupId         String
  group           SubscriptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String
  sharePercentage Decimal           @default(0)
  status          GroupMemberStatus @default(PENDING)
  paid            Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([groupId, email])
}

enum GroupMemberStatus {
  PENDING
  ACCEPTED
  DECLINED
}

